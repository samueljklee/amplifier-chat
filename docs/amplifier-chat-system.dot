digraph amplifier_chat {
    rankdir=LR
    fontname="Helvetica"
    fontsize=16
    label="amplifier-chat  ·  System Architecture"
    labelloc=t
    compound=true
    nodesep=0.5
    ranksep=1.0
    pad=0.3
    forcelabels=true

    node [fontname="Helvetica" fontsize=10 style=filled]
    edge [fontname="Helvetica" fontsize=8 color="#616161"]

    // ── External Systems ──────────────────────────────────────
    subgraph cluster_external {
        label="External Systems"
        style="filled,rounded"
        fillcolor="#F1F3F4"
        color="#9AA0A6"
        fontcolor="#5F6368"
        fontsize=11

        amplifier_distro [label="amplifier-distro\n(host application)" shape=box fillcolor="#DADCE0" color="#5F6368"]
        amplifier_core [label="amplifier-core\n(session engine)" shape=box fillcolor="#DADCE0" color="#5F6368"]
    }

    // ── Plugin Layer ──────────────────────────────────────────
    subgraph cluster_plugin {
        label="Plugin Layer (FastAPI)"
        style="filled,rounded"
        fillcolor="#E8F0FE"
        color="#1A73E8"
        fontcolor="#1967D2"
        fontsize=11

        create_router [label="create_router(state)\n<< entry point >>" shape=box fillcolor="#C6DAFC" color="#1A73E8" penwidth=2]

        // ── Route Groups ──────────────────────────────────────
        subgraph cluster_routes {
            label="Route Groups (10)"
            style="filled,dashed"
            fillcolor="#D2E3FC"
            color="#4285F4"
            fontcolor="#1967D2"
            fontsize=10

            spa_loader      [label="SPA Loader"                  shape=box fillcolor="#AECBFA" color="#1A73E8"]
            session_history [label="Session\nHistory"            shape=box fillcolor="#AECBFA" color="#1A73E8"]
            revision_change [label="Revision\nChange-Detection"  shape=box fillcolor="#AECBFA" color="#1A73E8"]
            pin_manager     [label="Pin Manager"                 shape=box fillcolor="#AECBFA" color="#1A73E8"]
            slash_command   [label="Slash-Command\nDispatcher"   shape=box fillcolor="#AECBFA" color="#1A73E8"]
            shell_sse       [label="Shell SSE\nStream"           shape=box fillcolor="#AECBFA" color="#1A73E8"]
            session_forker  [label="Session\nForker"             shape=box fillcolor="#AECBFA" color="#1A73E8"]
            feedback        [label="Feedback"                    shape=box fillcolor="#AECBFA" color="#1A73E8"]
            voice           [label="Voice"                       shape=box fillcolor="#AECBFA" color="#1A73E8"]
            config_api      [label="Config API"                  shape=box fillcolor="#AECBFA" color="#1A73E8"]
        }
    }

    // ── Session Backend ───────────────────────────────────────
    subgraph cluster_backend {
        label="Session Backend (Disk-Based)"
        style="filled,rounded"
        fillcolor="#E6F4EA"
        color="#34A853"
        fontcolor="#188038"
        fontsize=11

        stat_sort      [label="Phase 1: stat-sort\n(cheap, all files)"                          shape=box     fillcolor="#CEEAD6" color="#34A853"]
        parallel_read  [label="Phase 2: parallel\nThreadPoolExecutor\n(expensive, filtered)"    shape=box     fillcolor="#CEEAD6" color="#34A853"]
        mtime_size_sig [label="mtime_ns:size\nsignature"                                         shape=ellipse fillcolor="#A8DAB5" color="#34A853"]
        write_temp     [label="Write to\ntemp file"                                              shape=box     fillcolor="#CEEAD6" color="#34A853"]
        partial_guard  [label="Partial\nwrite?"                                                  shape=diamond fillcolor="#CEEAD6" color="#34A853"]
        rename_op      [label="Atomic\nrename"                                                   shape=box     fillcolor="#CEEAD6" color="#34A853"]
        disk_store     [label="Session Files\n(disk)"                                            shape=cylinder fillcolor="#A8DAB5" color="#137333" penwidth=2]
    }

    // ── Frontend ──────────────────────────────────────────────
    subgraph cluster_frontend {
        label="Frontend (Preact / HTM SPA)"
        style="filled,rounded"
        fillcolor="#FEF3E0"
        color="#F9AB00"
        fontcolor="#E37400"
        fontsize=11

        preact_spa    [label="Preact/HTM\nSPA Shell"              shape=box     fillcolor="#FEEFC3" color="#F9AB00" penwidth=2]
        input_drain   [label="Queue-based\nInput Drain\n(5-second cycle)" shape=box fillcolor="#FEEFC3" color="#F9AB00"]
        layered_guards [label="5 Layered\nGuards"                 shape=diamond fillcolor="#FEEFC3" color="#E37400"]
        sse_consumer  [label="SSE Event\nConsumer"                shape=box     fillcolor="#FEEFC3" color="#F9AB00"]
    }

    // ── Protocol / Contract Notes ─────────────────────────────
    sse_contract    [label="SSE Event Contract\n-----------\ntool:pre\ntool:output\ntool:post"   shape=note fillcolor="#FFF9C4" color="#F57F17" fontcolor="#E65100" fontsize=9]
    cmd_pattern     [label="Handler Pattern\n-----------\n_cmd_* dispatch"                       shape=note fillcolor="#FFF9C4" color="#F57F17" fontcolor="#E65100" fontsize=9]
    atomic_contract [label="Atomic Write\n-----------\nwrite -> temp\nrename -> final\n(never partial)" shape=note fillcolor="#FFF9C4" color="#F57F17" fontcolor="#E65100" fontsize=9]

    // ══════════════════════════════════════════════════════════
    // EDGES
    // ══════════════════════════════════════════════════════════

    // External → Plugin entry
    amplifier_distro -> create_router [label="mounts plugin\nrouter" color="#5F6368" fontcolor="#5F6368"]

    // create_router → Route Groups (fan-out)
    create_router -> spa_loader      [label="mounts" color="#1A73E8" fontcolor="#1967D2"]
    create_router -> session_history [label="mounts" color="#1A73E8" fontcolor="#1967D2"]
    create_router -> revision_change [label="mounts" color="#1A73E8" fontcolor="#1967D2"]
    create_router -> pin_manager     [label="mounts" color="#1A73E8" fontcolor="#1967D2"]
    create_router -> slash_command   [label="mounts" color="#1A73E8" fontcolor="#1967D2"]
    create_router -> shell_sse       [label="mounts" color="#1A73E8" fontcolor="#1967D2"]
    create_router -> session_forker  [label="mounts" color="#1A73E8" fontcolor="#1967D2"]
    create_router -> feedback        [label="mounts" color="#1A73E8" fontcolor="#1967D2"]
    create_router -> voice           [label="mounts" color="#1A73E8" fontcolor="#1967D2"]
    create_router -> config_api      [label="mounts" color="#1A73E8" fontcolor="#1967D2"]

    // amplifier-core → Shell SSE Stream (event proxying)
    amplifier_core -> shell_sse [label="tool:pre / tool:output\ntool:post" color="#D93025" fontcolor="#C5221F" style=bold penwidth=2]
    shell_sse -> sse_contract   [style=dashed color="#F57F17" arrowhead=none constraint=false]

    // Slash-Command → handler pattern note
    slash_command -> cmd_pattern [style=dashed color="#F57F17" arrowhead=none constraint=false]

    // ── Session Backend: 2-phase scan ─────────────────────────
    session_history -> stat_sort    [label="triggers\n2-phase scan"      color="#34A853" fontcolor="#188038"]
    stat_sort       -> disk_store   [label="stat() all files\n(cheap I/O)"    color="#34A853" fontcolor="#188038"]
    stat_sort       -> parallel_read [label="filtered\nfile set"           color="#34A853" fontcolor="#188038"]
    parallel_read   -> disk_store   [label="parallel reads\n(expensive I/O)"  color="#34A853" fontcolor="#188038"]

    // ── Session Backend: revision signatures ──────────────────
    revision_change -> mtime_size_sig [label="queries change\nsignature" color="#34A853" fontcolor="#188038"]
    mtime_size_sig  -> disk_store     [label="computed from\nfile metadata" color="#34A853" fontcolor="#188038"]

    // ── Session Backend: atomic write pipeline ────────────────
    pin_manager   -> write_temp    [label="pin/unpin\nrequest"  color="#34A853" fontcolor="#188038"]
    write_temp    -> partial_guard [label="integrity\ncheck"    color="#34A853" fontcolor="#188038"]
    partial_guard -> rename_op     [label="safe"                color="#137333" fontcolor="#137333"]
    rename_op     -> disk_store    [label="atomic\ncommit"      color="#137333" fontcolor="#137333"]
    pin_manager   -> atomic_contract [style=dashed color="#F57F17" arrowhead=none constraint=false]

    // ── Session Backend: other route sinks ────────────────────
    session_forker -> disk_store [label="branches session\nto new fork" color="#34A853" fontcolor="#188038"]
    feedback       -> disk_store [label="writes turn\nrating"           color="#34A853" fontcolor="#188038"]
    config_api     -> disk_store [label="reads/writes\nuser config"     color="#34A853" fontcolor="#188038"]

    // ── Frontend: SPA delivery ────────────────────────────────
    spa_loader -> preact_spa [label="serves SPA\n(HTML/JS)" color="#E37400" fontcolor="#E37400"]

    // ── Frontend: input pipeline ──────────────────────────────
    preact_spa    -> input_drain    [label="user input\nenqueued"          color="#F9AB00" fontcolor="#E37400"]
    input_drain   -> layered_guards [label="5s drain\ncycle"               color="#F9AB00" fontcolor="#E37400"]
    layered_guards -> slash_command [label="all guards pass\nsend command" color="#E37400" fontcolor="#C43E00" style=bold]

    // ── Frontend: SSE consumption ─────────────────────────────
    shell_sse    -> sse_consumer [label="SSE event\nstream"          color="#D93025" fontcolor="#C5221F" style=bold]
    sse_consumer -> preact_spa   [label="renders live\ntool events"   color="#F9AB00" fontcolor="#E37400"]

    // ── Frontend → Route consumption (secondary) ─────────────
    preact_spa -> session_history [label="list/read\nsessions"  color="#E37400" fontcolor="#B06000" style=dashed]
    preact_spa -> revision_change [label="poll for\nchanges"    color="#E37400" fontcolor="#B06000" style=dashed]
    preact_spa -> pin_manager     [label="pin/unpin"            color="#E37400" fontcolor="#B06000" style=dashed]
    preact_spa -> session_forker  [label="fork\nsession"        color="#E37400" fontcolor="#B06000" style=dashed]
    preact_spa -> feedback        [label="thumbs\nup/down"      color="#E37400" fontcolor="#B06000" style=dashed]
    preact_spa -> voice           [label="voice\nI/O"           color="#E37400" fontcolor="#B06000" style=dashed]
    preact_spa -> config_api      [label="read/write\nconfig"   color="#E37400" fontcolor="#B06000" style=dashed]

    // ── Legend ────────────────────────────────────────────────
    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#616161"
        fontcolor="#424242"
        fontsize=11
        margin=12

        node [fontsize=8 width=0.8 height=0.4]
        edge [style=invis]

        leg_box      [label="Process / Route"   shape=box      fillcolor="#E0E0E0" color="#616161"]
        leg_cylinder [label="Disk Storage"      shape=cylinder fillcolor="#E0E0E0" color="#616161"]
        leg_note     [label="Protocol /\nContract" shape=note  fillcolor="#FFF9C4" color="#F57F17"]
        leg_diamond  [label="Decision /\nGuard" shape=diamond  fillcolor="#E0E0E0" color="#616161"]
        leg_ellipse  [label="Data /\nSignature" shape=ellipse  fillcolor="#E0E0E0" color="#616161"]

        leg_box -> leg_cylinder -> leg_note -> leg_diamond -> leg_ellipse

        leg_blue   [label="Blue\nPlugin / Routing"    shape=box fillcolor="#AECBFA" color="#1A73E8" fontsize=7]
        leg_green  [label="Green\nSession Backend"    shape=box fillcolor="#CEEAD6" color="#34A853" fontsize=7]
        leg_orange [label="Orange\nFrontend"          shape=box fillcolor="#FEEFC3" color="#F9AB00" fontsize=7]
        leg_gray   [label="Gray\nExternal Systems"    shape=box fillcolor="#DADCE0" color="#5F6368" fontsize=7]

        leg_blue -> leg_green -> leg_orange -> leg_gray

        leg_solid  [label="Solid line = primary flow"   shape=plaintext fillcolor=white fontsize=7]
        leg_dashed [label="Dashed line = secondary flow" shape=plaintext fillcolor=white fontsize=7]
        leg_bold   [label="Bold line = event stream"    shape=plaintext fillcolor=white fontsize=7]

        leg_solid -> leg_dashed -> leg_bold
    }
}